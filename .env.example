# Use a small custom Coimbatore/Tamil Nadu extract for Railway.
# Create one from https://extract.bbbike.org/ or clip a larger PBF locally.
PBF_URL=https://download2.bbbike.org/osm/extract/planet_74.993,8.235_81.597,13.372.osm.pbf

# OSRM defaults.
OSRM_PROFILE=/opt/car.lua
OSRM_BASENAME=map
OSRM_ALGORITHM=mld
FORCE_REBUILD=false

# Railway provides PORT automatically. For local Docker, default is 5000.
PORT=5000
